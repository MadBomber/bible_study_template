---
layout: default
---

<article<% if data.section_number %> data-section="<%= data.section_number %>"<% end %><% if data.week %> data-week="<%= data.week %>"<% end %><% if data.day %> data-day="<%= data.day %>"<% end %><% if data.type %> data-type="<%= data.type %>"<% end %>>
  <h1><% if data.day %>Day <%= data.day %>: <%= data.title %><% elsif data.week && data.type == "discussion" %>Week <%= data.week %> Discussion Guide: <%= data.title %><% elsif data.week && data.layout == "memory_verse" %>Week <%= data.week %>: Memory Verse<% elsif data.week %>Week <%= data.week %>: <%= data.title %><% else %><%= data.title %><% end %></h1>

  <% if data.study_slug && data.week %>
  <%
    _mv = site.resources.find { |r|
      r.data[:study_slug] == data.study_slug &&
      r.data[:week].to_i  == data.week.to_i  &&
      r.data[:layout]     == "memory_verse"
    }
    _mv_slug  = data.study_slug
    _mv_pfx   = _mv_slug ? "/#{_mv_slug}" : ""
    _mv_phase = _mv ? site.data.send(_mv_slug.gsub('-','_')).week_phases.transform_keys(&:to_i)[data.week.to_i] : nil
    _mv_url   = _mv && _mv_phase ? "#{_mv_pfx}/#{_mv_phase}/week-#{'%02d' % data.week.to_i}/memory-verse/" : nil
  %>
  <% if _mv %>
  <aside class="day-memory-verse">
    <p class="dmv-label">Week <%= data.week %> Memory Verse</p>
    <blockquote class="dmv-text"><%= _mv.data[:verse_text] %></blockquote>
    <div class="dmv-ref-row">
      <cite class="dmv-ref"><%= _mv.data[:memory_verse] %> (<%= _mv.data[:translation] %>)</cite>
      <button class="mv-listen-btn dmv-icon-btn" data-reference="<%= _mv.data[:memory_verse] %>" data-verse="<%= _mv.data[:verse_text] %>" aria-label="Listen to memory verse" data-tooltip="Listen to verse">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
        </svg>
      </button>
      <% if _mv_url && data.layout != "memory_verse" %>
        <a href="<%= relative_url _mv_url %>" class="dmv-icon-btn" aria-label="Full memory verse page" data-tooltip="Memory verse page">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </a>
      <% end %>
    </div>
  </aside>
  <% end %>
  <% end %>

  <%= yield %>

  <% if data.day && _mv %>
  <aside class="day-memory-verse">
    <p class="dmv-label">Week <%= data.week %> Memory Verse</p>
    <blockquote class="dmv-text"><%= _mv.data[:verse_text] %></blockquote>
    <div class="dmv-ref-row">
      <cite class="dmv-ref"><%= _mv.data[:memory_verse] %> (<%= _mv.data[:translation] %>)</cite>
      <button class="mv-listen-btn dmv-icon-btn" data-reference="<%= _mv.data[:memory_verse] %>" data-verse="<%= _mv.data[:verse_text] %>" aria-label="Listen to memory verse" data-tooltip="Listen to verse">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
        </svg>
      </button>
      <% if _mv_url && data.layout != "memory_verse" %>
        <a href="<%= relative_url _mv_url %>" class="dmv-icon-btn" aria-label="Full memory verse page" data-tooltip="Memory verse page">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </a>
      <% end %>
    </div>
  </aside>
  <% end %>

  <% if data.week %>
  <%
    _study_slug   = data.study_slug
    _data_key     = _study_slug&.gsub('-', '_')
    _study_pfx    = _study_slug ? "/#{_study_slug}" : ""
    week          = data.week.to_i
    week_fmt      = "%02d" % week
    week_phases  = (_data_key ? site.data.send(_data_key).week_phases : site.data.week_phases).transform_keys(&:to_i)
    max_week     = week_phases.keys.max
    phase_dir    = week_phases[week]
    week_base    = "#{_study_pfx}/#{phase_dir}/week-#{week_fmt}"
    current_path = resource.relative_url.to_s.delete_prefix(site.base_path.to_s).chomp("/")
    prev_week    = week > 1 ? week - 1 : nil
    next_week    = week < max_week ? week + 1 : nil
    prev_phase   = prev_week ? week_phases[prev_week] : nil
    next_phase   = next_week ? week_phases[next_week] : nil
  %>
  <nav class="week-nav">
    <% if prev_week %>
      <a href="<%= relative_url "#{_study_pfx}/#{prev_phase}/week-#{'%02d' % prev_week}/overview/" %>" class="week-nav-arrow">&larr; Week <%= prev_week %></a>
    <% else %>
      <span class="week-nav-arrow"></span>
    <% end %>
    <div class="week-nav-pages">
      <%
        pages = [
          ["Overview",    "#{week_base}/overview/"],
          ["1",           "#{week_base}/day-1/"],
          ["2",           "#{week_base}/day-2/"],
          ["3",           "#{week_base}/day-3/"],
          ["4",           "#{week_base}/day-4/"],
          ["5",           "#{week_base}/day-5/"],
          ["Discussion",  "#{week_base}/discussion/"],
        ]
      %>
      <% pages.each do |label, path| %>
        <% is_current = current_path == path.chomp("/") %>
        <a href="<%= relative_url path %>" class="week-nav-page<%= ' current' if is_current %>"><%= label %></a>
      <% end %>
    </div>
    <% if next_week %>
      <a href="<%= relative_url "#{_study_pfx}/#{next_phase}/week-#{'%02d' % next_week}/overview/" %>" class="week-nav-arrow">Week <%= next_week %> &rarr;</a>
    <% else %>
      <span class="week-nav-arrow"></span>
    <% end %>
  </nav>
  <% end %>

  <section class="page-discussions" data-feature="discussions">
    <h2>Discussion</h2>
    <p class="discussions-note">Comments are powered by GitHub Discussions. To post, sign in with your GitHub account using the link below the reaction icons.</p>
    <div class="giscus"></div>
  </section>
</article>
