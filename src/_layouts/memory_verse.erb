---
layout: default
---

<article class="memory-verse-card" data-week="<%= data.week %>">

  <header class="mv-header">
    <span class="mv-phase"><%= data.section %></span>
    <h1>Week <%= data.week %>: Memory Verse</h1>
    <p class="mv-week-title"><%= data.title %></p>
  </header>

  <section class="mv-verse-row">
    <% if data.image %>
      <figure class="mv-image">
        <img src="<%= relative_url "/images/memory-verses/#{data.image}" %>" alt="Memory verse illustration for Week <%= data.week %>">
      </figure>
    <% end %>
    <div class="mv-verse">
      <blockquote class="mv-text">
        <%= data.verse_text %>
      </blockquote>
      <cite class="mv-reference"><%= data.memory_verse %></cite>
      <span class="mv-translation">(<%= data.translation %>)</span>
      <button class="mv-listen-btn"
              data-reference="<%= data.memory_verse %>"
              data-verse="<%= data.verse_text %>"
              aria-label="Listen to memory verse">
        <svg class="mv-listen-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
        </svg>
        <span class="mv-listen-label">Listen</span>
      </button>
    </div>
  </section>

  <section class="mv-context">
    <h2>Why This Verse</h2>
    <%= yield %>
  </section>

  <section class="mv-connections">
    <h2>Connections This Week</h2>
    <ul>
      <% data.connections&.each do |conn| %>
        <li><%= conn %></li>
      <% end %>
    </ul>
  </section>

  <footer class="mv-footer">
    <div class="mv-footer-actions">
      <!-- Mark Complete button inserted here by JS -->
    </div>

    <%
      _study_slug  = data.study_slug
      _data_key    = _study_slug&.gsub('-', '_')
      _study_pfx   = _study_slug ? "/#{_study_slug}" : ""
      week         = data.week.to_i
      week_phases  = (_data_key ? site.data.send(_data_key).week_phases : site.data.week_phases).transform_keys(&:to_i)
      study_cfg    = _data_key ? site.data.send(_data_key).study_config : site.data.study_config

      current_section_slug = week_phases[week]

      # All weeks in the current section
      section_weeks = week_phases.select { |_w, dir| dir == current_section_slug }.keys.sort

      first_week = section_weeks.first
      last_week  = section_weeks.last
      prev_section_slug = first_week > 1 ? week_phases[first_week - 1] : nil
      next_section_slug = last_week < week_phases.keys.max ? week_phases[last_week + 1] : nil

      # Section display names from study_config
      section_names = study_cfg["sections"].each_with_object({}) do |s, h|
        h[s["slug"]] = "Section #{s["number"]}"
      end

      prev_last_week  = prev_section_slug ? week_phases.select { |_w, dir| dir == prev_section_slug }.keys.max : nil
      next_first_week = next_section_slug ? week_phases.select { |_w, dir| dir == next_section_slug }.keys.min : nil
    %>

    <a href="<%= relative_url "#{_study_pfx}/memory-verses#all-verses" %>" class="mv-progress-link" target="_blank" rel="noopener">
      Check Your Progress — All Memory Verses
    </a>

    <nav class="week-nav">
      <% if prev_section_slug %>
        <a href="<%= relative_url "#{_study_pfx}/#{prev_section_slug}/week-#{'%02d' % prev_last_week}/memory-verse/" %>" class="week-nav-arrow">&larr; <%= section_names[prev_section_slug] %></a>
      <% else %>
        <span class="week-nav-arrow"></span>
      <% end %>
      <div class="week-nav-pages">
        <% section_weeks.each do |w| %>
          <% is_current = w == week %>
          <a href="<%= relative_url "#{_study_pfx}/#{current_section_slug}/week-#{'%02d' % w}/memory-verse/" %>" class="week-nav-page<%= ' current' if is_current %>"><%= w %></a>
        <% end %>
      </div>
      <% if next_section_slug %>
        <a href="<%= relative_url "#{_study_pfx}/#{next_section_slug}/week-#{'%02d' % next_first_week}/memory-verse/" %>" class="week-nav-arrow"><%= section_names[next_section_slug] %> &rarr;</a>
      <% else %>
        <span class="week-nav-arrow"></span>
      <% end %>
    </nav>
  </footer>

  <section class="page-discussions" data-feature="discussions">
    <h2>Discussion</h2>
    <p class="discussions-note">Comments are powered by GitHub Discussions. To post, sign in with your GitHub account using the link below the reaction icons.</p>
    <div class="giscus"></div>
  </section>

</article>
