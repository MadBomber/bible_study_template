---
layout: page
title: Memory Verses
study_slug: study-01
permalink: /study-01/memory-verses/
---

<h2>Memory Verses</h2>

<div id="mv-progress-summary"></div>

<%
  _mvs = site.resources
    .select { |r| r.data[:study_slug] == data.study_slug && r.data[:type] == "memory_verse" }
    .sort_by { |r| r.data[:week].to_i }
%>

<table class="mv-verses-table">
  <thead>
    <tr><th>Week</th><th>Verse</th><th>Reference</th><th></th></tr>
  </thead>
  <tbody>
    <% _mvs.each do |mv| %>
    <%
      _week      = mv.data[:week].to_i
      _mv_url    = mv.relative_url
      _reference = mv.data[:memory_verse]
      _verse     = mv.data[:verse_text]
      _trans     = mv.data[:translation]
    %>
    <tr>
      <td><a href="<%= _mv_url %>"><%= _week %></a></td>
      <td>"<%= _verse %>"</td>
      <td><%= _reference %> (<%= _trans %>)</td>
      <td class="mv-row-actions">
        <button class="mv-listen-btn dmv-icon-btn" data-reference="<%= _reference %>" data-verse="<%= _verse %>" aria-label="Listen to verse" data-tooltip="Listen to verse"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg></button>
        <a href="<%= _mv_url %>" class="dmv-icon-btn" aria-label="Memory verse page" data-tooltip="Memory verse page"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg></a>
      </td>
    </tr>
    <% end %>
  </tbody>
</table>
