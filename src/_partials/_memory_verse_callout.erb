<%
  # Locals: mv, mv_url, week, hide_book_link
%>
<% if mv %>
<% _mv_image = mv.data[:image] %>
<div class="<%= _mv_image ? 'mv-hero' : 'mv-hero mv-hero--no-image' %>">
  <% if _mv_image %>
  <figure class="mv-image">
    <img src="<%= relative_url "/images/memory-verses/#{_mv_image}" %>"
         alt="Memory verse illustration for Week <%= week %>">
  </figure>
  <% end %>
  <aside class="day-memory-verse">
    <p class="dmv-label">Week <%= week %> Memory Verse</p>
    <blockquote class="dmv-text"><%= mv.data[:verse_text] %></blockquote>
    <div class="dmv-ref-row">
      <cite class="dmv-ref"><%= mv.data[:memory_verse] %> (<%= mv.data[:translation] %>)</cite>
      <button class="mv-listen-btn dmv-icon-btn" data-reference="<%= mv.data[:memory_verse] %>" data-verse="<%= mv.data[:verse_text] %>" aria-label="Listen to memory verse" data-tooltip="Listen to verse">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
        </svg>
      </button>
      <% if mv_url && !hide_book_link %>
        <a href="<%= relative_url mv_url %>" class="dmv-icon-btn" aria-label="Full memory verse page" data-tooltip="Memory verse page">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </a>
      <% end %>
    </div>
  </aside>
</div>
<% end %>
